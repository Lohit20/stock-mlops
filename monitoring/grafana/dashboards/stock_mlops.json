{
  "title": "Stock MLOps",
  "uid": "stock-mlops-main",
  "schemaVersion": 38,
  "version": 2,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [

    { "id": 100, "type": "row", "title": "API Performance",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 }, "collapsed": false },

    {
      "id": 1,
      "title": "Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 1, "w": 12, "h": 8 },
      "targets": [{ "expr": "rate(api_requests_total[1m])", "legendFormat": "{{model}} — {{endpoint}}" }],
      "fieldConfig": { "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" } } }
    },

    {
      "id": 2,
      "title": "Latency p50 / p95 / p99 (s)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 1, "w": 12, "h": 8 },
      "targets": [
        { "expr": "histogram_quantile(0.50, rate(api_request_duration_seconds_bucket[1m]))", "legendFormat": "p50 {{model}}" },
        { "expr": "histogram_quantile(0.95, rate(api_request_duration_seconds_bucket[1m]))", "legendFormat": "p95 {{model}}" },
        { "expr": "histogram_quantile(0.99, rate(api_request_duration_seconds_bucket[1m]))", "legendFormat": "p99 {{model}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "color": { "mode": "palette-classic" } } }
    },

    {
      "id": 3,
      "title": "Prediction Error Rate",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 9, "w": 12, "h": 8 },
      "targets": [{ "expr": "rate(api_prediction_errors_total[5m])", "legendFormat": "errors/s — {{model}}" }],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "fixed", "fixedColor": "red" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "red",   "value": 0.01 }
          ]}
        }
      }
    },

    {
      "id": 4,
      "title": "Requests by Model",
      "type": "piechart",
      "gridPos": { "x": 12, "y": 9, "w": 12, "h": 8 },
      "targets": [{ "expr": "sum by (model) (api_requests_total)", "legendFormat": "{{model}}" }]
    },

    {
      "id": 5,
      "title": "Error Rate %",
      "type": "gauge",
      "gridPos": { "x": 0, "y": 17, "w": 6, "h": 4 },
      "targets": [{
        "expr": "100 * sum(rate(api_prediction_errors_total[5m])) / (sum(rate(api_requests_total[5m])) + 0.001)",
        "legendFormat": "Error %"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "min": 0, "max": 100,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green",  "value": null },
            { "color": "yellow", "value": 1 },
            { "color": "red",    "value": 5 }
          ]}
        }
      }
    },

    {
      "id": 6,
      "title": "Avg Duration by Model (s)",
      "type": "bargauge",
      "gridPos": { "x": 6, "y": 17, "w": 18, "h": 4 },
      "targets": [{
        "expr": "rate(api_request_duration_seconds_sum[5m]) / rate(api_request_duration_seconds_count[5m])",
        "legendFormat": "{{model}}"
      }],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },

    { "id": 101, "type": "row", "title": "Cache Performance",
      "gridPos": { "x": 0, "y": 21, "w": 24, "h": 1 }, "collapsed": false },

    {
      "id": 7,
      "title": "Cache Hit Rate %",
      "type": "gauge",
      "gridPos": { "x": 0, "y": 22, "w": 8, "h": 8 },
      "targets": [{
        "expr": "100 * sum(rate(api_cache_hits_total[5m])) / (sum(rate(api_cache_hits_total[5m])) + sum(rate(api_cache_misses_total[5m])) + 0.001)",
        "legendFormat": "Hit Rate"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "min": 0, "max": 100,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red",    "value": null },
            { "color": "yellow", "value": 50 },
            { "color": "green",  "value": 80 }
          ]}
        }
      }
    },

    {
      "id": 8,
      "title": "Cache Hits vs Misses (rate/s)",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 22, "w": 16, "h": 8 },
      "targets": [
        { "expr": "sum by (model) (rate(api_cache_hits_total[1m]))",   "legendFormat": "hits {{model}}" },
        { "expr": "sum by (model) (rate(api_cache_misses_total[1m]))", "legendFormat": "misses {{model}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },

    { "id": 102, "type": "row", "title": "Data Drift & Retraining",
      "gridPos": { "x": 0, "y": 30, "w": 24, "h": 1 }, "collapsed": false },

    {
      "id": 9,
      "title": "Drift Score Over Time",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 31, "w": 16, "h": 8 },
      "targets": [{ "expr": "pipeline_drift_score", "legendFormat": "{{dataset}}" }],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit", "min": 0, "max": 1,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green",  "value": null },
            { "color": "yellow", "value": 0.3 },
            { "color": "red",    "value": 0.5 }
          ]},
          "custom": { "thresholdsStyle": { "mode": "line+area" } }
        }
      }
    },

    {
      "id": 10,
      "title": "Drift Detected",
      "type": "stat",
      "gridPos": { "x": 16, "y": 31, "w": 4, "h": 4 },
      "targets": [{ "expr": "pipeline_drift_detected{dataset=\"price_features\"}", "legendFormat": "" }],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "OK",    "color": "green" } } },
            { "type": "value", "options": { "1": { "text": "DRIFT", "color": "red"   } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "red",   "value": 1 }
          ]}
        }
      },
      "options": { "colorMode": "background", "graphMode": "none" }
    },

    {
      "id": 11,
      "title": "Retraining Required",
      "type": "stat",
      "gridPos": { "x": 20, "y": 31, "w": 4, "h": 4 },
      "targets": [{ "expr": "pipeline_needs_retraining{dataset=\"price_features\"}", "legendFormat": "" }],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "No",  "color": "green"  } } },
            { "type": "value", "options": { "1": { "text": "YES", "color": "orange" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green",  "value": null },
            { "color": "orange", "value": 1 }
          ]}
        }
      },
      "options": { "colorMode": "background", "graphMode": "none" }
    },

    {
      "id": 12,
      "title": "Retraining Triggered (total)",
      "type": "stat",
      "gridPos": { "x": 16, "y": 35, "w": 8, "h": 4 },
      "targets": [{ "expr": "pipeline_retraining_triggered_total", "legendFormat": "" }],
      "fieldConfig": { "defaults": { "unit": "short", "color": { "fixedColor": "orange", "mode": "fixed" } } },
      "options": { "colorMode": "value", "graphMode": "area" }
    },

    { "id": 103, "type": "row", "title": "Model Performance",
      "gridPos": { "x": 0, "y": 39, "w": 24, "h": 1 }, "collapsed": false },

    {
      "id": 13,
      "title": "Model RMSE (lower is better)",
      "type": "bargauge",
      "gridPos": { "x": 0, "y": 40, "w": 12, "h": 8 },
      "targets": [{ "expr": "pipeline_model_rmse", "legendFormat": "{{model_type}}" }],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green",  "value": null },
            { "color": "yellow", "value": 10 },
            { "color": "red",    "value": 20 }
          ]}
        }
      },
      "options": { "orientation": "horizontal", "displayMode": "gradient" }
    },

    {
      "id": 14,
      "title": "Directional Accuracy (higher is better)",
      "type": "bargauge",
      "gridPos": { "x": 12, "y": 40, "w": 12, "h": 8 },
      "targets": [{ "expr": "pipeline_model_directional_accuracy", "legendFormat": "{{model_type}}" }],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit", "min": 0, "max": 1,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red",    "value": null },
            { "color": "yellow", "value": 0.50 },
            { "color": "green",  "value": 0.60 }
          ]}
        }
      },
      "options": { "orientation": "horizontal", "displayMode": "gradient" }
    },

    {
      "id": 15,
      "title": "Model MAPE Over Time (%)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 48, "w": 12, "h": 8 },
      "targets": [{ "expr": "pipeline_model_mape", "legendFormat": "{{model_type}}" }],
      "fieldConfig": { "defaults": { "unit": "percent" } }
    },

    {
      "id": 16,
      "title": "RMSE Trend Over Time",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 48, "w": 12, "h": 8 },
      "targets": [{ "expr": "pipeline_model_rmse", "legendFormat": "{{model_type}}" }],
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "palette-classic" } } }
    },

    { "id": 104, "type": "row", "title": "Pipeline Lifecycle",
      "gridPos": { "x": 0, "y": 56, "w": 24, "h": 1 }, "collapsed": false },

    {
      "id": 17,
      "title": "Total Pipeline Runs",
      "type": "stat",
      "gridPos": { "x": 0, "y": 57, "w": 6, "h": 4 },
      "targets": [{ "expr": "pipeline_runs_total", "legendFormat": "" }],
      "fieldConfig": { "defaults": { "unit": "short", "color": { "fixedColor": "blue", "mode": "fixed" } } },
      "options": { "colorMode": "value", "graphMode": "area" }
    },

    {
      "id": 18,
      "title": "Last Pipeline Duration",
      "type": "stat",
      "gridPos": { "x": 6, "y": 57, "w": 6, "h": 4 },
      "targets": [{ "expr": "pipeline_duration_seconds", "legendFormat": "" }],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green",  "value": null },
            { "color": "yellow", "value": 3600 },
            { "color": "red",    "value": 7200 }
          ]}
        }
      },
      "options": { "colorMode": "background" }
    },

    {
      "id": 19,
      "title": "Pipeline Runs per Day",
      "type": "stat",
      "gridPos": { "x": 12, "y": 57, "w": 6, "h": 4 },
      "targets": [{ "expr": "increase(pipeline_runs_total[24h])", "legendFormat": "" }],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },

    {
      "id": 20,
      "title": "Retraining Runs per Week",
      "type": "stat",
      "gridPos": { "x": 18, "y": 57, "w": 6, "h": 4 },
      "targets": [{ "expr": "increase(pipeline_retraining_triggered_total[7d])", "legendFormat": "" }],
      "fieldConfig": { "defaults": { "unit": "short", "color": { "fixedColor": "orange", "mode": "fixed" } } }
    }

  ]
}
