name: stock-mlops

python_env: python_env.yaml

entry_points:
  train_lstm:
    parameters:
      n_steps_in:  {type: int,   default: 90}
      n_steps_out: {type: int,   default: 30}
      window:      {type: int,   default: 30}
      epochs:      {type: int,   default: 50}
      batch_size:  {type: int,   default: 32}
      val_split:   {type: float, default: 0.1}
    command: "python -m src.training.train_lstm
              --n_steps_in {n_steps_in}
              --n_steps_out {n_steps_out}
              --window {window}
              --epochs {epochs}
              --batch_size {batch_size}
              --val_split {val_split}"

  train_tft:
    parameters:
      max_epochs:    {type: int,   default: 30}
      batch_size:    {type: int,   default: 64}
      learning_rate: {type: float, default: 0.001}
      hidden_size:   {type: int,   default: 64}
      n_steps_in:    {type: int,   default: 90}
      n_steps_out:   {type: int,   default: 30}
    command: "python -m src.training.train_tft
              --max_epochs {max_epochs}
              --batch_size {batch_size}
              --learning_rate {learning_rate}
              --hidden_size {hidden_size}"

  train_timesfm:
    parameters:
      context_len:      {type: int,  default: 512}
      horizon_len:      {type: int,  default: 30}
      fine_tune:        {type: str,  default: "true"}
      fine_tune_epochs: {type: int,  default: 5}
    command: "python -m src.training.train_timesfm
              --context_len {context_len}
              --horizon_len {horizon_len}
              --fine_tune {fine_tune}
              --fine_tune_epochs {fine_tune_epochs}"

  train_arm:
    parameters:
      p:           {type: int,   default: 5}
      d:           {type: int,   default: 1}
      q:           {type: int,   default: 0}
      n_steps_out: {type: int,   default: 30}
      test_split:  {type: float, default: 0.2}
    command: "python -m src.training.train_arm
              --p {p} --d {d} --q {q}
              --n_steps_out {n_steps_out}
              --test_split {test_split}"

  compare_models:
    command: "python -m src.evaluation.compare_models"

  run_pipeline:
    command: "python -m src.ingestion.scraper"
