.coverage
htmlcov
tests/

# Notebooks
notebooks/
*.ipynb
.ipynb_checkpoints

# IDE
.vscode
.idea

# OS
.DS_Store
Thumbs.db

# Monitoring data (runtime-generated)
monitoring/reports/

# DVC cache (large, not needed in image)
.dvc/cache
.dvc/tmp
